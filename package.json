{
  "name": "fasit-frontend",
  "version": "297.0.0",
  "description": "Fasit frontend",
  "type": "commonjs",
  "packageManager": "pnpm@10.33.0",
  "main": "server.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node production_server.js",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('dist', {recursive:true, force:true})\"",
    "dev": "vite",
    "mocked": "concurrently \"cross-env NODE_ENV=standalone FASIT_URL=/mockapi PORT=6969 node ./server.js\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "precommit": "pretty-quick --staged"
  },
  "keywords": [
    "node",
    "express",
    "react",
    "redux",
    "fasit"
  ],
  "author": "Frode Sundby",
  "license": "ISC",
  "devDependencies": {
    "@babel/preset-react": "^7.28.5",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "less": "^4.6.4",
    "mousetrap": "^1.6.5",
    "prettier": "^3.8.3",
    "pretty-quick": "^4.2.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-redux": "^9.2.0",
    "react-select": "^5.10.2",
    "redux": "^5.0.1",
    "redux-logger": "^3.0.6",
    "redux-saga": "^1.4.2",
    "redux-thunk": "^3.1.0",
    "sinon": "^22.0.0",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "bootstrap": "^5.3.8",
    "bootswatch": "^5.3.8",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "history": "^5.3.0",
    "prom-client": "^15.1.3",
    "react-router-dom": "^7.15.0",
    "xml-formatter": "^3.7.0"
  }
}
