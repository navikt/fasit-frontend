{
  "name": "fasit-frontend",
  "version": "297.0.0",
  "description": "Fasit frontend",
  "type": "commonjs",
  "packageManager": "pnpm@10.33.0",
  "main": "server.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node production_server.js",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('dist', {recursive:true, force:true})\"",
    "prebuild": "npm run clean && node -e \"const fs=require('fs'); fs.mkdirSync('dist',{recursive:true}); fs.cpSync('src/images','dist/images',{recursive:true}); fs.cpSync('src/index.html','dist/index.html')\"",
    "premocked": "npm run prebuild",
    "predev": "npm run prebuild",
    "dev": "cross-env NODE_PATH=./src NODE_ENV=development PORT=4242 node ./server.js",
    "build": "cross-env NODE_ENV=production webpack --config webpack.config.prod.js",
    "mocked": "cross-env NODE_ENV=standalone NODE_PATH=./src PORT=6969 FASIT_URL=http://localhost:6969/mockapi node ./server.js",
    "test": "cross-env NODE_ENV=production NODE_PATH=./src mocha --require @babel/register --require ./test/setup.js --recursive ./test/new",
    "test:watch": "npm test -- --watch",
    "precommit": "pretty-quick --staged"
  },
  "keywords": [
    "node",
    "express",
    "react",
    "redux",
    "fasit"
  ],
  "author": "Frode Sundby",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/polyfill": "^7.12.1",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.0",
    "@babel/register": "^7.25.9",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "babel-loader": "^9.2.1",
    "body-parser": "^1.19.0",
    "chai": "^4.5.0",
    "chai-spies": "^1.1.0",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "css-loader": "^6.11.0",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "^1.15.8",
    "file-loader": "^6.2.0",
    "jsdom": "^9.11.0",
    "less": "^4.1.2",
    "less-loader": "^12.3.2",
    "less-plugin-clean-css": "^1.5.1",
    "mocha": "^10.8.2",
    "mousetrap": "^1.6.3",
    "prettier": "^3.8.3",
    "pretty-data": "^0.40.0",
    "pretty-quick": "^3.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.2.0",
    "react-select": "^5.10.2",
    "redux": "^5.0.1",
    "redux-logger": "^3.0.6",
    "redux-mock-store": "^1.5.5",
    "redux-saga": "^1.3.0",
    "redux-thunk": "^2.4.2",
    "sinon": "^11.1.2",
    "style-loader": "^3.3.4",
    "url-loader": "^4.1.1",
    "webpack": "^5.106.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-middleware": "^3.7.3",
    "webpack-hot-middleware": "^2.25.4"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "bootstrap": "^5.3.8",
    "bootswatch": "^5.3.8",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "history": "^5.3.0",
    "prom-client": "^15.1.3",
    "prop-types": "^15.8.1",
    "react-router-dom": "^6.28.0"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12"
  }
}
